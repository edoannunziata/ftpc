{
  "name": "ftpc",
  "version": "0.1.0",
  "description": "File transfer client with modular storage backends.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/index.ts",
    "format": "bunx prettier --write . --ignore-unknown --ignore-path .prettierignore",
    "format:check": "bunx prettier --check . --ignore-unknown --ignore-path .prettierignore",
    "hooks:install": "bun run scripts/install-hooks.ts",
    "prepare": "bun run hooks:install",
    "test": "bun test tests",
    "typecheck": "bunx tsc --noEmit",
    "build:exe": "bun build --target=bun src/index.ts --compile --outfile dist/ftpc"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/ssh2": "^1.15.5",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.32.0",
    "@azure/storage-file-datalake": "^12.30.0",
    "basic-ftp": "^6.0.1",
    "ssh2": "^1.17.0"
  }
}
